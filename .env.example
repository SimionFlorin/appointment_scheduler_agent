# Auth.js (generate with: npx auth secret)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_TRUST_HOST=true
# AUTH_URL is auto-detected locally and on Vercel. Set it on other hosts (Railway, Fly, etc.):
# AUTH_URL=https://your-production-domain.com

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase PostgreSQL (find these in Supabase Dashboard → Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# WhatsApp webhook verification (see README for details)
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key


# Facebook App ID and Secret (may need to be updated when I switch app/to tech provider)
FACEBOOK_APP_ID=FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=FACEBOOK_APP_SECRET

# Comma-separated origins allowed to load Next dev assets (fixes ngrok + next dev cross-origin warning).
# Example: DEV_TUNNEL_ORIGINS=https://abc123.ngrok-free.app
DEV_TUNNEL_ORIGINS=

# Revolut Merchant API - Live (https://business.revolut.com)
# Used when NODE_ENV=production or REVOLUT_USE_LIVE=1.
# REVOLUT_API_URL defaults to https://merchant.revolut.com if unset.
REVOLUT_API_SECRET_KEY=your-revolut-live-secret-key
REVOLUT_API_PUBLIC_KEY=your-revolut-live-public-key
# REVOLUT_API_URL=https://merchant.revolut.com

# Revolut Merchant API - Sandbox (https://sandbox-business.revolut.com)
# Used in dev / non-production NODE_ENV.
# REVOLUT_SANDBOX_API_URL defaults to https://sandbox-merchant.revolut.com.
REVOLUT_SANDBOX_API_SECRET_KEY=your-revolut-sandbox-secret-key
REVOLUT_SANDBOX_API_PUBLIC_KEY=your-revolut-sandbox-public-key
# REVOLUT_SANDBOX_API_URL=https://sandbox-merchant.revolut.com

# Revolut Webhook Signing Secret (returned when you create a webhook via the API)
# Run: npm run webhook:create https://your-domain.com/api/webhooks/revolut
REVOLUT_WEBHOOK_SIGNING_SECRET=
REVOLUT_LIVE_WEBHOOK_SIGNING_SECRET=

# Force the Revolut Checkout widget to hit live even when NODE_ENV !== "production".
# Leave unset to default to sandbox in dev. Set to `1` to test against live.
# REVOLUT_USE_LIVE=1

# Shared secret for the monthly billing cron. Vercel Cron sends it as
# `Authorization: Bearer $CRON_SECRET`. Generate with: openssl rand -hex 32
# If unset, /api/cron/billing-renew refuses to run.
CRON_SECRET=