# Auth.js (generate with: npx auth secret)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_TRUST_HOST=true
# AUTH_URL is auto-detected locally and on Vercel. Set it on other hosts (Railway, Fly, etc.):
# AUTH_URL=https://your-production-domain.com

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase PostgreSQL (find these in Supabase Dashboard → Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# WhatsApp webhook verification (see README for details)
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key


# Facebook App ID and Secret (may need to be updated when I switch app/to tech provider)
FACEBOOK_APP_ID=FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=FACEBOOK_APP_SECRET

# Revolut Merchant API - Sandbox (https://sandbox-business.revolut.com)
REVOLUT_API_URL=https://sandbox-merchant.revolut.com
REVOLUT_API_SECRET_KEY=your-revolut-sandbox-secret-key

# Revolut Merchant API - Live (https://business.revolut.com)
REVOLUT_LIVE_API_URL=https://merchant.revolut.com
REVOLUT_LIVE_SECRET_KEY=your-revolut-live-secret-key

# Revolut Webhook Signing Secret (returned when you create a webhook via the API)
# Run: npm run webhook:create https://your-domain.com/api/webhooks/revolut
REVOLUT_WEBHOOK_SIGNING_SECRET=
REVOLUT_LIVE_WEBHOOK_SIGNING_SECRET=

# Card number that routes checkout to sandbox instead of live Revolut
REVOLUT_TEST_CARD_NUMBER=4929420573595709
NEXT_PUBLIC_REVOLUT_TEST_CARD_NUMBER=4929420573595709